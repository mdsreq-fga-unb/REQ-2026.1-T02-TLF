{
  "info": {
    "name": "TLT Finanças - Institution API",
    "description": "Collection para testar os endpoints de instituições financeiras",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "institutionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "token",
      "value": "SEU_TOKEN_AQUI",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. POST /institution - Criar instituição (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('institutionId', json.id);",
              "pm.test('Tem id', () => pm.expect(json.id).to.exist);",
              "pm.test('Nome correto', () => pm.expect(json.name).to.equal('Nubank'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/institution",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nubank\",\n  \"color\": \"#8A05BE\",\n  \"logoUrl\": \"https://nubank.com.br/logo.png\"\n}"
        }
      }
    },
    {
      "name": "2. POST /institution - Nome duplicado (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 409', () => pm.response.to.have.status(409));"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/institution",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nubank\",\n  \"color\": \"#8A05BE\"\n}"
        }
      }
    },
    {
      "name": "3. POST /institution - Dados inválidos (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/institution",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"color\": \"cor-invalida\"\n}"
        }
      }
    },
    {
      "name": "4. POST /institution - Sem token (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/institution",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Teste\",\n  \"color\": \"#000000\"\n}"
        }
      }
    },
    {
      "name": "5. GET /institution - Listar (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('É array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/institution",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "6. GET /institution/:id - Buscar por ID (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('ID correto', () => pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get('institutionId')));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/institution/{{institutionId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "7. GET /institution/:id - ID inexistente (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/institution/id-inexistente",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "8. PATCH /institution/:id - Atualizar (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Cor atualizada', () => pm.expect(pm.response.json().color).to.equal('#FF0000'));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/institution/{{institutionId}}",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"color\": \"#FF0000\"\n}"
        }
      }
    },
    {
      "name": "9. DELETE /institution/:id - Deletar (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Mensagem correta', () => pm.expect(pm.response.json().message).to.equal('Instituição removida com sucesso'));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/institution/{{institutionId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "10. GET /institution/:id - Após deletar (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/institution/{{institutionId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    }
  ]
}
