generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
}

enum Currency {
  BRL
  // TODO: Add other currencies after the MVP
}

enum InvoiceStatus {
  OPEN
  CLOSED
}

enum InvoicePaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  PAID
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED // wasnt paid
}

enum NotificationType {
  BUDGET_WARNING          // 80% do orçamento atingido
  BUDGET_EXCEEDED         // 100% atingido

  RECURRENCE_DUE_WARNING  // recorrência vence em X dias
  RECURRENCE_DUE          // recorrência vence hoje

  INVOICE_CLOSING_WARNING // fatura FECHA em X dias 
  INVOICE_CLOSING         // fatura fecha hoje
  INVOICE_DUE_WARNING     // fatura VENCE em X dias
  INVOICE_DUE             // fatura vence hoje
  INVOICE_OVERDUE         // fatura já passou do vencimento
  INVOICE_PAID            // fatura paga
  INVOICE_PARTIALLY_PAID  // fatura parcialmente paga
}

enum TableName {
  CATEGORIES
  SUB_CATEGORIES
  INSTITUTIONS
  BUDGETS
  ACCOUNTS
  INVOICES
  RECURRENCES
  TRANSACTIONS
  NOTIFICATIONS
}
// --- Core ---

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categories   Category[]
  institutions Institution[]
  budgets      Budget[]
  notifications Notification[]
  deletedRecords DeletedRecord[]

  @@map("users")
}

model Category {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  name  String
  icon  String
  color String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  budgets       Budget[]
  recurrences   Recurrence[]
  transactions  Transaction[]
  subCategories SubCategory[]

  @@unique([userId, name])
  @@map("categories")
}

model SubCategory {
  id String @id @default(uuid())

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")

  name  String
  icon  String   // icon and color should match parent category in app code when creating a subcategory
  color String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recurrences  Recurrence[]
  transactions Transaction[]

  @@map("sub_categories")
}

model Institution {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  name    String
  color   String
  logoUrl String? @map("logo_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("institutions")
}

model Budget {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId String   @map("category_id")

  name        String
  amountLimit Int    @map("amount_limit")
  month       Int
  year        Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

// --- Accounts & money ---

model Account {
  id String @id @default(uuid())

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  institutionId String      @map("institution_id")

  name    String
  type    AccountType @default(CHECKING)
  balance Int         @default(0)

  // credit cards only:
  closingDay  Int? @map("closing_day") 
  dueDay      Int? @map("due_day")
  creditLimit Int? @default(0) @map("credit_limit")

  currency Currency @default(BRL)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // One account is linked to transactions in two ways:
  // - "AccountTransactions"     -> this row is the source account (accountId on Transaction)
  // - "TransferDestinations"   -> this row is the other leg of a transfer (destinationAccountId)
  invoices             Invoice[]
  recurrences          Recurrence[]
  transactions         Transaction[] @relation("AccountTransactions")
  transferDestinations Transaction[] @relation("TransferDestinations")

  @@map("accounts")
}

// Credit-card invoices: spending posts to the card; paying the invoice reduces what you owe (never > 0 as “credit” on the invoice).
model Invoice {
  id String @id @default(uuid())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  status         InvoiceStatus        @default(OPEN)
  paymentStatus  InvoicePaymentStatus @default(NOT_PAID)
  referenceMonth Int @map("reference_month")
  referenceYear  Int @map("reference_year")
  totalAmount    Int @default(0) @map("total_amount")
  paidAmount     Int @default(0) @map("paid_amount")

  // ALWAYS the same of it's account:
  closingDay     Int @map("closing_day")
  dueDay         Int @map("due_day")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]

  @@map("invoices")
}

// Repeating charges (subscription, bill, loan payment, etc.)
model Recurrence {
  id String @id @default(uuid())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?   @map("category_id")

  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  subCategoryId String?      @map("sub_category_id")

  description String
  amount      Int
  isActive    Boolean   @default(true) @map("is_active")
  chargeDate  Int       @map("charge_date")
  startDate   DateTime  @default(now()) @map("start_date")
  endDate     DateTime? @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]

  @@map("recurrences")
}

// Ledger line: expense, income, or one leg of a transfer. Optional links to invoice (card),
// recurrence (generated charges), and installments (split purchase across months).
model Transaction {
  id String @id @default(uuid())

  // Source account — every transaction debits/credits this account first.
  account   Account @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  // When type is TRANSFER, this is the other account (credit side). Null for non-transfers.
  destinationAccount   Account? @relation("TransferDestinations", fields: [destinationAccountId], references: [id], onDelete: SetNull)
  destinationAccountId String?  @map("destination_account_id")

  // Recurrences create rows as PENDING until the user (or a job) marks them COMPLETED; one-off tx usually starts COMPLETED.
  status TransactionStatus @default(COMPLETED)
  type   TransactionType   @default(EXPENSE)
  
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?   @map("category_id")

  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  subCategoryId String?      @map("sub_category_id")

  amount      Int
  date        DateTime @default(now())
  description String?

  recurrence   Recurrence? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  recurrenceId String?     @map("recurrence_id")

  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceId String?  @map("invoice_id")

  // Installments: e.g. 1000 in 10x -> 10 rows sharing the same reference, installmentNumber 1..N, installmentTotal N.
  // Wire to invoice / closing logic for credit cards when you implement card billing.
  installmentReference String? @map("installment_reference")
  installmentNumber    Int?    @map("installment_number")
  installmentTotal     Int?    @map("installment_total")

  receiptUrl String? @map("receipt_url") // Institution-issued receipt URL — post-MVP
  externalId String? @map("external_id") // Open Finance / bank tx id — post-MVP

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("transactions")
}

model Notification {
  id          String           @id @default(uuid())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String           @map("user_id")

  type        NotificationType
  title       String
  description String
  isRead      Boolean          @default(false) @map("is_read")
  
  primaryActionLabel   String? @map("primary_action_label")
  primaryAction   String? @map("primary_action")
  secondaryActionLabel String? @map("secondary_action_label")
  secondaryAction String? @map("secondary_action")
  
  icon  String
  color String
  
  referenceId   String @map("reference_id")   // ex: budget id, recurrence id
  referenceType String @map("reference_type") // ex: "budget", "recurrence"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("notifications")
}

model DeletedRecord {
  id         String   @id @default(uuid())
  recordId   String   @map("record_id")
  tableName  TableName   @map("table_name")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  deletedAt  DateTime @default(now()) @map("deleted_at")
  @@index([userId, deletedAt])
  @@map("deleted_records")
}
  // ─── POST-MVP: SPLIT TRANSACTIONS ───────────────────────────────────────────
  // Allows a single purchase to be split across multiple categories.
  //
  // Two supported flows:
  //
  // A) BOTTOM-UP (during purchase — user doesn't know the total yet)
  //    User adds items per category as they shop. The sum of splits becomes
  //    the final transaction total. Good for real-time tracking at the store.
  //
  // B) TOP-DOWN (after purchase — user knows the total)
  //    User enters the total first, then distributes across categories.
  //    The app tracks remaining unallocated amount in real time.
  //    Useful for categorizing a receipt after the fact.
  //
  // Schema changes needed when implementing:
  //   1. Make categoryId optional (parent transaction has no category)
  //   2. Add parentId self-relation (children point to their parent)
  //   3. Debit balance ONCE on the parent — children never affect balance
  //   4. Exclude parent transactions that have splits from category reports
  //      to avoid double-counting (filter: parentId IS NULL AND no splits,
  //      OR parentId IS NOT NULL)
  //
  // parentId String?       @map("parent_id")
  // parent   Transaction?  @relation("TransactionSplit", fields: [parentId], references: [id], onDelete: Cascade)
  // splits   Transaction[] @relation("TransactionSplit")
  //
  // FRONTEND: Add a option "Split transaction" to the transaction form, when the user selects this option, a new form should be displayed to the user to split the transaction into multiple categories.
  // ────────────────────────────────────────────────────────────────────────────