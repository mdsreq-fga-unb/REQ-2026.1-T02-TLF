{
  "name": "tlt",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/backend",
    "apps/mobile"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "precommit": "lint-staged",
    "prepush": "npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@shopify/react-native-skia": "2.2.12",
    "class-validator": "^0.14.4",
    "react-native-reanimated": "~4.1.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
